#!/bin/bash

set -e

DIR="$(dirname "$(realpath "$0")")"
ROOT="$(realpath "${DIR}/..")"

test -f "$1" && spec="$1" || spec=$(./bin/download-spec)

openapi_generator_version=$(xargs < "${ROOT}/.openapi-generator/VERSION")
image="openapitools/openapi-generator-cli:v${openapi_generator_version}"

# Build the custom templates from source instead of keeping full copies in the
# repo: extract the pristine templates from the pinned generator version, then
# apply our patches (templates/typescript-axios/*.mustache.patch) on top. When
# a generator bump changes a template we customize, the patch fails to apply
# and this script aborts, instead of the copies silently drifting from
# upstream.
build_dir="${ROOT}/tmp/templates/typescript-axios"
rm -rf "$build_dir"
mkdir -p "$build_dir/pristine"

docker run --rm --user "$(id -u):$(id -g)" \
  -v "$build_dir/pristine":/pristine \
  "$image" author template -g typescript-axios -o /pristine > /dev/null

for patch_file in "${ROOT}"/templates/typescript-axios/*.mustache.patch; do
  template="$(basename "${patch_file%.patch}")"
  cp "$build_dir/pristine/$template" "$build_dir/$template"
  patch -s -F0 "$build_dir/$template" "$patch_file"
done

rm -rf "$build_dir/pristine"

docker run --rm \
  -v "$(pwd)":/output \
  -v "$(realpath "$spec")":/spec.yml \
  "$image" generate \
  -i /spec.yml \
  -g typescript-axios \
  -o /output \
  -t /output/tmp/templates/typescript-axios \
  -p npmName=tremendous,supportsES6=true,modelPropertyNaming=original
