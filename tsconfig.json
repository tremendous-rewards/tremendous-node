{
  "compilerOptions": {
    "declaration": true,
    "target": "ES6",
    "module": "commonjs",
    "noImplicitAny": true,
    "outDir": "dist",
    "rootDir": ".",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": false,
    "typeRoots": [
      "node_modules/@types"
    ],
    "types": ["node"]
  },
  "exclude": [
    "dist",
    "test",
    "node_modules"
  ]
}
